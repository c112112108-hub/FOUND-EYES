import cv2
import numpy as np
from google.colab.patches import cv2_imshow

# 載入分類器
face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')

def detect_pupils(img_path):
    img = cv2.imread(img_path)
    if img is None: return print('無法讀取圖片')

    img_display = img.copy()
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

    # 1. 偵測臉部
    faces = face_cascade.detectMultiScale(gray, 1.1, 5)

    for (x, y, w, h) in faces:
        # 2. 定義眼睛精確區域 (臉部高度的 22% 到 45%)
        eye_roi_y_start = y + int(h * 0.22)
        eye_roi_y_end = y + int(h * 0.45)
        roi_gray = gray[eye_roi_y_start:eye_roi_y_end, x:x+w]
        roi_color = img_display[eye_roi_y_start:eye_roi_y_end, x:x+w]

        # 3. 強化眼睛區域對比度 (CLAHE)
        clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))
        roi_enhanced = clahe.apply(roi_gray)

        # 4. 雙邊濾波保留邊緣並去噪
        blurred = cv2.bilateralFilter(roi_enhanced, 9, 75, 75)

        # 5. 霍夫圓偵測
        circles = cv2.HoughCircles(
            blurred, cv2.HOUGH_GRADIENT, dp=1.2, minDist=w/4,
            param1=50, param2=20, minRadius=int(w/40), maxRadius=int(w/10)
        )

        if circles is not None:
            circles = np.round(circles[0, :]).astype('int')
            # 依照圓內平均亮度排序，取最暗的兩個
            scored = []
            for (cx, cy, r) in circles:
                if cx-r < 0 or cy-r < 0 or cx+r >= roi_gray.shape[1] or cy+r >= roi_gray.shape[0]: continue
                avg_val = np.mean(roi_gray[cy-r:cy+r, cx-r:cx+r])
                scored.append((cx, cy, r, avg_val))

            scored = sorted(scored, key=lambda x: x[3])[:2]

            for (cx, cy, r, score) in scored:
                # 6. 二次修正中心：尋找圓內的絕對最暗點
                eye_patch = blurred[max(0,cy-r):min(roi_gray.shape[0],cy+r), max(0,cx-r):min(roi_gray.shape[1],cx+r)]
                _, _, min_loc, _ = cv2.minMaxLoc(eye_patch)
                correct_cx = cx - r + min_loc[0]
                correct_cy = cy - r + min_loc[1]

                # 標記瞳孔 (紅圈 + 白心)
                cv2.circle(roi_color, (correct_cx, correct_cy), r, (0, 0, 255), 3)
                cv2.circle(roi_color, (correct_cx, correct_cy), 2, (255, 255, 255), -1)

    cv2_imshow(cv2.resize(img_display, (800, 600)))

